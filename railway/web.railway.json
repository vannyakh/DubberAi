{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "docker/web.Dockerfile",
    "watchPatterns": [
      "apps/web/**",
      "packages/**",
      "rust/**",
      "docker/web.Dockerfile",
      "docker/nginx.conf",
      "pnpm-lock.yaml"
    ]
  },
  "deploy": {
    "healthcheckPath": "/",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
