{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "docker/worker.Dockerfile",
    "watchPatterns": [
      "services/render-worker/**",
      "packages/**",
      "docker/worker.Dockerfile",
      "pnpm-lock.yaml"
    ]
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
