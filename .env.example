# .env.example — single shared env file at the repo root.
# Copy to `.env`. Every process loads it from here:
#   - API + workers via @dubbercut/env (packages/env)
#   - web app via Vite envDir (apps/web/vite.config.ts)
#   - prisma via dotenv-cli (apps/api db:* scripts)
# Machine-local overrides go in `.env.local` (also gitignored).

# ── AI ──────────────────────────────────────────────────────────
# 302.AI (https://302.ai) unified AI gateway — one key for all LLM/AI services.
# Only the API server reads this; clients call /api/ai/* instead.
API_KEY_302=
# Optional overrides
API_302_BASE_URL=https://api.302.ai
AI_302_CHAT_MODEL=gemini-3.5-flash

# ── API server (apps/api) ───────────────────────────────────────
# MongoDB Atlas connection string (include a database name in the path)
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/dubbercut?retryWrites=true&w=majority"
# JWT signing secret — required in production
AUTH_SECRET=
#PORT=4000

# Optional: Redis cache (API falls back to the DB when unset or down)
#REDIS_URL="redis://localhost:6379"
# Optional: RabbitMQ job events (workers poll /api/jobs/claim when unset)
#RABBITMQ_URL="amqp://guest:guest@localhost:5672"

# ── Upload storage ──────────────────────────────────────────────
# Cloudflare R2 (S3-compatible). When all four R2_* vars are set the API
# stores uploads in R2; otherwise files go to local disk (UPLOAD_DIR,
# on Railway: the attached volume).
#R2_ACCOUNT_ID=
#R2_BUCKET=
#R2_ACCESS_KEY_ID=
#R2_SECRET_ACCESS_KEY=
# Optional: public bucket or custom domain — downloads redirect here
# instead of using presigned URLs.
#R2_PUBLIC_URL=https://media.example.com
# Presigned URL lifetime in seconds (default 3600)
#R2_SIGNED_URL_TTL=3600
# Force a driver explicitly: r2 | local
#STORAGE_DRIVER=local
#UPLOAD_DIR=./uploads

# ── Workers (services/*) ────────────────────────────────────────
#API_URL=http://localhost:4000
#POLL_INTERVAL_MS=3000

# ── Web client (apps/web) ───────────────────────────────────────
# Web client -> API server base URL (defaults to http://localhost:4000)
#VITE_API_URL=http://localhost:4000
