# .env.example — single shared env file at the repo root.
# Copy to `.env`. Every process loads it from here:
#   - API + workers via @dubbercute/env (packages/env)
#   - web app via Vite envDir (apps/web/vite.config.ts)
#   - prisma via dotenv-cli (apps/api db:* scripts)
# Machine-local overrides go in `.env.local` (also gitignored).

# ── AI ──────────────────────────────────────────────────────────
# 302.AI (https://302.ai) unified AI gateway — one key for all LLM/AI services.
# Only the API server reads this; clients call /api/ai/* instead.
API_KEY_302=
# Optional overrides
API_302_BASE_URL=https://api.302.ai
AI_302_CHAT_MODEL=gemini-3.5-flash

# ── API server (apps/api) ───────────────────────────────────────
# MongoDB Atlas connection string (include a database name in the path)
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/dubbercute?retryWrites=true&w=majority"
# JWT signing secret — required in production
AUTH_SECRET=
#PORT=4000

# Optional: Redis cache (API falls back to the DB when unset or down)
#REDIS_URL="redis://localhost:6379"
# Optional: RabbitMQ job events (workers poll /api/jobs/claim when unset)
#RABBITMQ_URL="amqp://guest:guest@localhost:5672"

# ── Workers (services/*) ────────────────────────────────────────
#API_URL=http://localhost:4000
#POLL_INTERVAL_MS=3000

# ── Web client (apps/web) ───────────────────────────────────────
# Web client -> API server base URL (defaults to http://localhost:4000)
#VITE_API_URL=http://localhost:4000
