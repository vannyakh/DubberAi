# .env.example
# 302.AI (https://302.ai) unified AI gateway — one key for all LLM/AI services
API_KEY_302=
# Optional overrides
API_302_BASE_URL=https://api.302.ai
AI_302_CHAT_MODEL=gemini-3.5-flash

# Web client -> API server base URL (defaults to http://localhost:4000).
# The API server is the only process that reads API_KEY_302; the web app
# calls /api/ai/* instead of talking to 302.ai directly.
#VITE_API_URL=http://localhost:4000
