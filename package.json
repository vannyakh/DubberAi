{
  "name": "dubbercut",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "turbo dev --filter=@dubbercut/web",
    "dev:all": "turbo dev",
    "dev:api": "turbo dev --filter=@dubbercut/api",
    "dev:desktop": "pnpm --filter @dubbercut/desktop dev:app",
    "dev:mobile": "pnpm --filter @dubbercut/mobile start",
    "db:push": "pnpm --filter @dubbercut/api db:push",
    "smoke-api": "node scripts/smoke-api.mjs",
    "build": "turbo build",
    "build:wasm": "wasm-pack build rust/wasm --target web --out-dir pkg --release",
    "dev:wasm": "wasm-pack build rust/wasm --target web --out-dir pkg --dev",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "check-env": "node scripts/check-env.mjs"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "~5.8.2"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "patchedDependencies": {
      "ffmpeg-expo@0.0.2": "patches/ffmpeg-expo@0.0.2.patch"
    }
  }
}
